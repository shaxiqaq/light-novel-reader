{
  "name": "light-novel-reader",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "npm run build && wrangler dev",
    "site:deploy": "wrangler deploy --config site/wrangler.jsonc",
    "cf:dev": "wrangler dev --config worker/wrangler.jsonc",
    "cf:deploy": "wrangler deploy --config worker/wrangler.jsonc",
    "cf:d1:init": "wrangler d1 execute light-novel-reader-progress --config worker/wrangler.jsonc --file=./worker/schema.sql",
    "cf:d1:init:remote": "wrangler d1 execute light-novel-reader-progress --config worker/wrangler.jsonc --remote --file=./worker/schema.sql",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^1.0.0",
    "tailwind-merge": "^3.5.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.32.2",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-vue": "^5.2.4",
    "tailwindcss": "^4.2.2",
    "vite": "^6.2.6",
    "wrangler": "^4.82.2"
  }
}
